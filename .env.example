# PostgreSQL
POSTGRES_DB=causaops
POSTGRES_USER=causaops
POSTGRES_PASSWORD=causaops_local
DATABASE_URL=postgresql+psycopg://causaops:causaops_local@db:5432/causaops

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Web (used by the Next.js server)
API_INTERNAL_URL=http://api:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
DEMO_INTERNAL_URL=http://demo-service:8100

# Controlled Demo Service behavior
STABLE_DELAY_SECONDS=0.05
TIMEOUT_DELAY_SECONDS=2.5

# Deterministic incident detection
DETECTION_WINDOW_MINUTES=5
DETECTION_INTERVAL_SECONDS=30
MINIMUM_REQUEST_COUNT=5
ERROR_RATE_THRESHOLD=0.10
LATENCY_P95_THRESHOLD_MS=2000
HEALTH_CHECK_FAILURE_THRESHOLD=3
DEPLOYMENT_CORRELATION_MINUTES=15

# Reserved for Phase 4. Never commit real keys.
GROQ_API_KEY=
GROQ_TEST_MODEL=openai/gpt-oss-20b
GROQ_PRIMARY_MODEL=openai/gpt-oss-120b
GROQ_REASONING_EFFORT=medium
GROQ_TIMEOUT_SECONDS=30
DIAGNOSIS_MAX_EVIDENCE=30
