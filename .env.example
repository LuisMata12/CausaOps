# PostgreSQL
POSTGRES_DB=causaops
POSTGRES_USER=causaops
POSTGRES_PASSWORD=causaops_local
DATABASE_URL=postgresql+psycopg://causaops:causaops_local@db:5432/causaops

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Web (used by the Next.js server)
API_INTERNAL_URL=http://api:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
DEMO_INTERNAL_URL=http://demo-service:8100

# Controlled Demo Service behavior
STABLE_DELAY_SECONDS=0.05
TIMEOUT_DELAY_SECONDS=2.5

# Reserved for Phase 4. Never commit real keys.
LLM_PROVIDER=disabled
GROQ_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
